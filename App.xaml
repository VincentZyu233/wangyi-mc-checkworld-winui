<Application
    x:Class="WangyiMCCheckworld.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WangyiMCCheckworld">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Win11 Theme Colors -->
            <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="#1A1A1A"/>
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#5C5C5C"/>
            <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="#F3F3F3"/>
            <SolidColorBrush x:Key="ControlStrongFillColorDefaultBrush" Color="#E5E5E5"/>
            <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="#D1D1D1"/>
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#0078D4"/>
            
            <!-- Win11 Acrylic Material Background -->
            <AcrylicBrush x:Key="LayerFillColorDefaultBrush"
                TintOpacity="0"
                BlurOpacity="0"
                BackgroundSource="HostBackdrop"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>